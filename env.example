# ──────────────────────────────────────────────────────────
# TechCup Fútbol - Variables de Entorno
# Copia este archivo como .env y completa los valores
# ¡NUNCA subas el archivo .env al repositorio!
# ──────────────────────────────────────────────────────────

# Base de Datos
DB_NAME=techcupdb
DB_USER=postgres
DB_PASSWORD=TU_CONTRASEÑA_SEGURA_AQUI

# JWT
JWT_SECRET=TU_CLAVE_JWT_LARGA_Y_SEGURA_DE_AL_MENOS_256_BITS
JWT_EXPIRATION=3600000

# (Opcional) Puerto de la app
APP_PORT=8080
